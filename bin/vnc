#!/bin/bash

VERSION="1.0.0"
export HOME="${HOME:-/home/$(whoami)}"

DISPLAY_NUM="${DISPLAY_NUM:-1}"
VNC_DISPLAY=":$DISPLAY_NUM"
NOVNC_PORT="${NOVNC_PORT:-6080}"
VNC_PORT=$((5900 + DISPLAY_NUM))
MEASURE_SCRIPT="/home/w3c_offical/projects/vnc-proxy/measure_window.py"
MEASURE_PORT=$((13430 + DISPLAY_NUM))
VNC_GEOMETRY="1920x1080"
VNC_DEPTH="24"

show_help() {
    cat << EOF
Usage: vnc [COMMAND]

Manage VNC server with noVNC web interface and measure_window service.

Commands:
  --start, -s           Start VNC and noVNC services
  --stop                Stop VNC and noVNC services
  --restart, -r         Restart VNC and noVNC services
  --status              Show status of running services and systemd services
  --install-service     Install systemd services for auto-start on boot
  --pwd                 Set/change VNC password
  --link                Create symlink to ~/.local/bin for global access
  --version, -v         Show version information
  --help, -h            Show this help message

Environment Variables:
  DISPLAY_NUM   VNC display number (default: 1)
  NOVNC_PORT    noVNC web port (default: 6080)

Examples:
  vnc --start                    # Start with defaults
  vnc -s                         # Short form
  DISPLAY_NUM=2 vnc --start      # Start Display :2
  NOVNC_PORT=6081 vnc --start    # Use port 6081
  vnc --status                   # Check status
  sudo vnc --install-service     # Install auto-start services
  vnc --pwd                      # Set password
  vnc --link                     # Link to global bin
  vnc --stop                     # Stop services

Access: http://localhost:$NOVNC_PORT/vnc.html
EOF
    exit 0
}

show_status() {
    echo "=== VNC Services Status ==="
    echo
    
    # Check systemd services
    echo "Systemd Services:"
    VNC_SERVICE_INSTALLED=0
    NOVNC_SERVICE_INSTALLED=0
    
    if [ -f "/etc/systemd/system/vncserver@.service" ]; then
        VNC_SERVICE_INSTALLED=1
        VNC_STATUS=$(systemctl is-active vncserver@1.service 2>&1)
        echo "  vncserver@1.service: $VNC_STATUS"
    else
        echo "  vncserver@1.service: NOT INSTALLED"
    fi
    
    if [ -f "/etc/systemd/system/novnc.service" ]; then
        NOVNC_SERVICE_INSTALLED=1
        NOVNC_STATUS=$(systemctl is-active novnc.service 2>&1)
        echo "  novnc.service: $NOVNC_STATUS"
    else
        echo "  novnc.service: NOT INSTALLED"
    fi
    echo
    
    # Show running processes
    echo "Running Processes:"
    echo "  VNC Servers:"
    if pgrep -fa "Xtigervnc" > /dev/null; then
        pgrep -fa "Xtigervnc" | sed 's/^/    /'
    else
        echo "    No VNC servers running"
    fi
    echo
    echo "  noVNC (websockify):"
    if pgrep -fa "websockify" > /dev/null; then
        pgrep -fa "websockify" | sed 's/^/    /'
    else
        echo "    No websockify processes running"
    fi
    echo
    echo "  measure_window:"
    if pgrep -fa "measure_window.py" > /dev/null; then
        pgrep -fa "measure_window.py" | sed 's/^/    /'
    else
        echo "    No measure_window processes running"
    fi
    echo
    
    echo "Listening Ports:"
    ss -tln | grep -E ":(59[0-9]{2}|60[0-9]{2}|134[0-9]{2})" | sed 's/^/  /' || echo "  No VNC-related ports listening"
    echo
    
    echo "Log Files:"
    LOG_FOUND=0
    for log in /tmp/measure_*.log /tmp/vnc_reload_*.log; do
        if [ -f "$log" ]; then
            echo "  $log"
            LOG_FOUND=1
        fi
    done
    [ $LOG_FOUND -eq 0 ] && echo "  No log files found"
    echo
    
    # Notify if services not installed
    if [ $VNC_SERVICE_INSTALLED -eq 0 ] || [ $NOVNC_SERVICE_INSTALLED -eq 0 ]; then
        echo "⚠️  WARNING: Systemd services not installed!"
        echo "   Services will NOT auto-start after reboot."
        echo
        echo "   To install auto-start services, run:"
        echo "   sudo vnc --install-service"
        echo
    fi
    
    exit 0
}

stop_services() {
    echo "Stopping VNC services..."
    pkill -f "Xtigervnc"
    pkill -f "websockify"
    pkill -f "measure_window.py"
    sleep 1
    echo "Services stopped"
    exit 0
}

start_services() {
    echo "Starting VNC services for Display $VNC_DISPLAY on port $NOVNC_PORT..."
    
    if pgrep -f "Xtigervnc $VNC_DISPLAY" > /dev/null; then
        echo "VNC server already running on $VNC_DISPLAY"
    else
        echo "Starting VNC server on display $VNC_DISPLAY"
        export HOME="${HOME:-/home/$(whoami)}"
        PASSWD_FILE="$HOME/.vnc/passwd"
        tigervncserver $VNC_DISPLAY -geometry $VNC_GEOMETRY -depth $VNC_DEPTH \
                       -xstartup "$HOME/.vnc/xstartup" -PasswordFile "$PASSWD_FILE" -SecurityTypes VncAuth
    fi

    if pgrep -f "websockify.*$NOVNC_PORT" > /dev/null; then
        echo "noVNC already running on port $NOVNC_PORT"
    else
        echo "Starting noVNC web interface on port $NOVNC_PORT"
        websockify --web /usr/share/novnc/ $NOVNC_PORT localhost:$VNC_PORT &
    fi

    if [ -f "$MEASURE_SCRIPT" ]; then
        if ss -tln | grep -q ":$MEASURE_PORT "; then
            echo "measure_window already running on port $MEASURE_PORT"
        else
            echo "Starting measure_window on port $MEASURE_PORT"
            export HOME="${HOME:-/home/$(whoami)}"
            XAUTH_PATH="$HOME/.Xauthority"
            DISPLAY="$VNC_DISPLAY" XAUTHORITY="$XAUTH_PATH" nohup /usr/bin/python3 "$MEASURE_SCRIPT" --display "$VNC_DISPLAY" --port "$MEASURE_PORT" > "/tmp/measure_${MEASURE_PORT}.log" 2>&1 &
        fi
    fi

    echo "Services started. Access at http://localhost:$NOVNC_PORT/vnc.html"
    exit 0
}

restart_services() {
    echo "Restarting VNC services..."
    stop_services
    sleep 2
    start_services
}

install_service() {
    if [ "$EUID" -ne 0 ]; then
        echo "Error: --install-service requires root privileges"
        echo "Please run: sudo vnc --install-service"
        exit 1
    fi
    
    echo "Installing VNC systemd services..."
    
    # Create vncserver@.service
    cat > /etc/systemd/system/vncserver@.service << 'EOFVNC'
[Unit]
Description=Remote desktop service (VNC)
After=syslog.target network.target

[Service]
Type=forking
User=w3c_offical
ExecStart=/usr/bin/vncserver :%i -geometry 1920x1080 -depth 24
ExecStop=/usr/bin/vncserver -kill :%i
Restart=on-failure

[Install]
WantedBy=multi-user.target
EOFVNC
    
    # Create novnc.service
    cat > /etc/systemd/system/novnc.service << 'EOFNOVNC'
[Unit]
Description=noVNC websockify proxy
After=vncserver@1.service
Requires=vncserver@1.service

[Service]
Type=simple
User=w3c_offical
ExecStart=/usr/bin/websockify --web=/usr/share/novnc 6080 localhost:5901
Restart=on-failure

[Install]
WantedBy=multi-user.target
EOFNOVNC
    
    # Reload and enable
    systemctl daemon-reload
    systemctl enable vncserver@1.service novnc.service
    
    echo "✅ Services installed and enabled!"
    echo
    echo "Services will auto-start on next boot."
    echo "To start now: sudo systemctl start vncserver@1.service novnc.service"
    echo "To check status: vnc --status"
    
    exit 0
}

case "$1" in
    --help|-h)
        show_help
        ;;
    --version|-v)
        echo "vnc version $VERSION"
        exit 0
        ;;
    --status)
        show_status
        ;;
    --start|-s)
        start_services
        ;;
    --stop)
        stop_services
        ;;
    --restart|-r)
        restart_services
        ;;
    --install-service)
        install_service
        ;;
    --pwd)
        vncpasswd
        exit 0
        ;;
    --link)
        SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
        TARGET_PATH="$HOME/.local/bin/vnc"
        mkdir -p ~/.local/bin
        [ -e "$TARGET_PATH" ] && rm -f "$TARGET_PATH"
        ln -s "$SCRIPT_PATH" "$TARGET_PATH"
        echo "Symlink created: $TARGET_PATH -> $SCRIPT_PATH"
        echo "Make sure ~/.local/bin is in your PATH"
        exit 0
        ;;
    *)
        echo "Error: Unknown command '$1'"
        echo "Run 'vnc --help' for usage information"
        exit 1
        ;;
esac


